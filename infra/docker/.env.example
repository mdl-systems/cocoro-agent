# cocoro-agent — 環境変数設定ファイル
# cp .env.example .env してから編集してください

# ── 認証 ───────────────────────────────────────────────────────────────────
# cocoro-coreと同じAPIキーを指定（必須）
COCORO_API_KEY=cocoro-2026

# ── cocoro-core 接続先 ──────────────────────────────────────────────────────
# 同一miniPCで動かす場合: http://cocoro-core:8001  (Docker内部名前解決)
# 別のminiPCのcocoro-coreに接続する場合: http://192.168.50.92:8001
COCORO_CORE_URL=http://192.168.50.92:8001

# ── このノードの設定 ────────────────────────────────────────────────────────
# サービスポート
AGENT_PORT=8002

# ノード識別子（Cocoro OSの複数miniPC管理で使用）
# 例: main-node / minipc-b / minipc-c
NODE_ID=minipc-b

# ノードの表示名（管理コンソールに表示される）
NODE_NAME=弁護士・税理士ノード

# ── ロール設定 ──────────────────────────────────────────────────────────────
# このノードが担当する専門職ロール（カンマ区切り）
# 指定できるロール: researcher, engineer, lawyer, accountant, financial_advisor
# 未指定の場合は全ロールを担当
AGENT_ROLES=lawyer,accountant

# ── Webpack / セキュリティ ──────────────────────────────────────────────────
WEBHOOK_SECRET=change-me-in-production

# ── ネットワーク ────────────────────────────────────────────────────────────
# Dockerネットワーク名（cocoro-coreと揃える）
DOCKER_NETWORK=cocoro-network

# ── ログ ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── データベース（cocoro-coreと共有する場合のみ設定） ────────────────────────
# 別miniPCで動かす場合、DBはcocoro-coreのminiPCを参照する
# POSTGRES_PASSWORD=cocoro_secret
# DATABASE_URL=postgresql://cocoro:cocoro_secret@192.168.50.92:5432/cocoro_db
# REDIS_URL=redis://192.168.50.92:6379/0
