# cocoro-agent — 環境変数設定ファイル
# cp .env.example .env してから編集してください

# ── 認証 ───────────────────────────────────────────────────────────────────
# cocoro-coreと同じAPIキーを指定（必須）
COCORO_API_KEY=cocoro-2026

# ── Gemini API 設定 ──────────────────────────────────────────
# cocoro-coreと同じAPIキーを使用（必須）
GEMINI_API_KEY=
# モデル名（cocoro-coreと履底のモデルを使用）
GEMINI_MODEL=gemini-2.5-flash

# ── cocoro-core 接続先 ──────────────────────────────────────────────────────
# 同一miniPCで動かす場合: http://cocoro-core:8000  (Docker内部名前解決)
# 別のminiPCのcocoro-coreに接続する場合: http://192.168.50.92:8000
COCORO_CORE_URL=http://cocoro-core:8000

# ── このノードの設定 ────────────────────────────────────────────────────────
# サービスポート（nginx経由で公開されるのでホスト側は任意）
AGENT_PORT=8002

# ノード識別子（Cocoro OSの複数miniPC管理で使用）
# 例: main-node / minipc-b / minipc-c
NODE_ID=main-node

# ノードの表示名（管理コンソールに表示される）
NODE_NAME=メインノード

# ── ロール設定 ──────────────────────────────────────────────────────────────
# このノードが担当する専門職ロール（カンマ区切り）
# 指定できるロール: researcher, engineer, lawyer, accountant, financial_advisor, medical_advisor
# 未指定の場合は全ロールを担当
AGENT_ROLES=researcher,engineer,lawyer,accountant,financial_advisor,medical_advisor

# ── cocoro-console 自動Webhook登録先 ──────────────────────
# 設定すると起動時にコンソールのWebhookエンドポイントに自動登録される
# CONSOLE_URL=http://cocoro-console:3000

# ── ノード間通信 (Phase 7: エージェント間リレー) ───────────────────────
# このノードの識別子（省略するとホスト名を使用）
NODE_ID=minipc-a
# ノード間HMAC認証の共有シークレット（全ノードで統一すること）
NODE_SHARED_SECRET=change-me-node-secret
# 既知の他ノードURL（カンマ区切り、GET /relay/nodes で疎通確認）
# KNOWN_NODES=http://minipc-b:8002,http://minipc-c:8002

# ── セキュリティ ────────────────────────────────────────────────────────────
WEBHOOK_SECRET=change-me-in-production

# ── ネットワーク ────────────────────────────────────────────────────────────
# Dockerネットワーク名（cocoro-coreと揃える）
DOCKER_NETWORK=cocoro-network

# ── ログ ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── データベース・Redis ──────────────────────────────────────────────────────
# cocoro-coreと同一ネットワーク内なら内部ホスト名で接続できる
# POSTGRES_PASSWORD=cocoro_secret
# DATABASE_URL=postgresql://cocoro:cocoro_secret@cocoro-postgres:5432/cocoro_db
# REDIS_URL=redis://cocoro-redis:6379/0
#
# 別miniPCで動かす場合はIPアドレスで指定:
# DATABASE_URL=postgresql://cocoro:cocoro_secret@192.168.50.92:5432/cocoro_db
# REDIS_URL=redis://192.168.50.92:6379/0
